@{
	ViewData["Title"] = "Stock - Putty";
}

<div class="stock-container">

	<h2 class="stock-title">Stock - Putty</h2>

	<div class="stock-toolbar">
		<input type="text"
			   class="stock-search"
			   placeholder="Search by name or brand" />

		<button type="button" class="btn-primary" onclick="location.href='/Stock/AddPutty'">
			Add Putty
		</button>
		<button type="button" class="btn-primary" onclick="addToBill()">Add to Bill</button>
	</div>

	<div class="table-wrapper">
		<table class="stock-table">
			<thead>
				<tr>
					<th>Select</th>
					<th>Putty Name</th>
					<th>Brand</th>
					<th>Category</th>
					<th>Quantity(Kg)</th>
					<th>Price/Kg</th>
					<th>Status</th>
					<th>Action</th>
				</tr>
			</thead>

			<tbody>
				@if (TempData["PuttyName"] != null)
				{
					<tr>
						<td><input type="checkbox" /></td>
						<td>@TempData["PuttyName"]</td>
						<td>@TempData["Brand"]</td>
						<td>@TempData["Category"]</td>
						<td>@TempData["Quantity"]</td>
						<td>@TempData["Price"]</td>
						<td><span class="status ok">Ok</span></td>
						<td>
							<button class="btn-edit">Edit</button>
							<button class="btn-delete">Delete</button>
						</td>
					</tr>
				}
				<tr>
					<td><input type="checkbox" name="selectedPaints" value="White Cement" /></td>
					<td>White Cement</td>
					<td>Birla White</td>
					<td>Interior</td>
					<td>120</td>
					<td>₹180</td>
					<td><span class="status ok">Ok</span></td>
					<td>
						<button type="button" class="btn-edit">Edit</button>
						<button type="button" class="btn-delete">Delete</button>
					</td>
				</tr>

				<tr>
					<td><input type="checkbox" name="selectedPaints" value="Acrylic" /></td>
					<td>Acrylic</td>
					<td>Asians Paints</td>
					<td>Interior</td>
					<td>15</td>
					<td>₹220</td>
					<td><span class="status low">Low</span></td>
					<td>
						<button type="button" class="btn-edit">Edit</button>
						<button type="button" class="btn-delete">Delete</button>
					</td>
				</tr>

				<tr>
					<td><input type="checkbox" name="selectedPaints" value="Polymer" /></td>
					<td>Polymer</td>
					<td>Birla White</td>
					<td>Interior</td>
					<td>60</td>
					<td>₹210</td>
					<td><span class="status ok">Ok</span></td>
					<td>
						<button type="button" class="btn-edit">Edit</button>
						<button type="button" class="btn-delete">Delete</button>
					</td>
				</tr>
			</tbody>
		</table>
	</div>

</div>



<div id="editModal" class="category-modal">

	<div class="modal-box">

		<h3>Edit Paint</h3>

		<input id="editName" type="text" placeholder="Paint Name">
		<input id="editBrand" type="text" placeholder="Brand">
		<input id="editCategory" type="text" placeholder="Category">
		<input id="editQuantity" type="number" placeholder="Quantity">
		<input id="editPrice" type="number" placeholder="Price">

		<div class="modal-buttons">
			<button class="btn-primary" onclick="saveEdit()">Save</button>
			<button onclick="closeEditModal()">Cancel</button>
		</div>

	</div>

</div>

<script>
	function addToBill() {
		let items = [];
		document.querySelectorAll('input[type="checkbox"][name="selectedPaints"]:checked').forEach(cb => items.push(cb.value));
		let billItems = localStorage.getItem("billItems");
		billItems = billItems ? billItems.split("|") : [];
		items.forEach(i => { if(!billItems.includes(i)) billItems.push(i); });
		localStorage.setItem("billItems", billItems.join("|"));
		window.location.href = '/Bill/Index';
	}
</script>
<script>

	let currentRow = null;

	document.addEventListener("click", function(e){

		// DELETE ROW
		if(e.target.classList.contains("btn-delete")){
			if(confirm("Delete this item?")){
				let row = e.target.closest("tr");
				row.remove();
			}
		}

		// OPEN EDIT MODAL
		if(e.target.classList.contains("btn-edit")){

			currentRow = e.target.closest("tr");

			document.getElementById("editName").value = currentRow.cells[1].innerText;
			document.getElementById("editBrand").value = currentRow.cells[2].innerText;
			document.getElementById("editCategory").value = currentRow.cells[3].innerText;
			document.getElementById("editQuantity").value = currentRow.cells[4].innerText;
			document.getElementById("editPrice").value = currentRow.cells[5].innerText;

			document.getElementById("editModal").style.display = "flex";
		}

	});

	function saveEdit(){

		currentRow.cells[1].innerText = document.getElementById("editName").value;
		currentRow.cells[2].innerText = document.getElementById("editBrand").value;
		currentRow.cells[3].innerText = document.getElementById("editCategory").value;
		currentRow.cells[4].innerText = document.getElementById("editQuantity").value;
		currentRow.cells[5].innerText = document.getElementById("editPrice").value;

		closeEditModal();
	}

	function closeEditModal(){
		document.getElementById("editModal").style.display = "none";
	}

</script>