@{
    ViewData["Title"] = "Stock - Exterior";
}

<div class="stock-container">

    <h2 class="stock-title">Stock - Exterior</h2>

    <div class="stock-toolbar">
        <input type="text"
               class="stock-search"
               placeholder="Search by name, brand, or" />
        <button type="button"
                class="btn-primary"
                onclick="window.location.href='/Stock/AddExteriorPaint'">
            Add Paint
        </button>

        <!-- UPDATED BUTTON -->
        <button type="button" class="btn-primary" onclick="addToBill()">Add to Bill</button>
    </div>

    <div class="table-wrapper">
        <table class="stock-table">
            <thead>
                <tr>
                    <th>Select</th>
                    <th>Paint Name</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th>Quantity(L)</th>
                    <th>Price/L</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            @if (TempData.Peek("PaintName") != null)
            {
                <tr>
                    <td><input type="checkbox" /></td>
                    <td>@TempData.Peek("PaintName")</td>
                    <td>@TempData.Peek("Brand")</td>
                    <td>@TempData.Peek("Category")</td>
                    <td>@TempData.Peek("Quantity")</td>
                    <td>@TempData.Peek("Price")</td>
                    <td><span class="status ok">Ok</span></td>
                    <td>
                        <button class="btn-edit">Edit</button>
                        <button class="btn-delete">Delete</button>
                    </td>
                </tr>
            }
            <tbody>
                <tr>
                    <td><input type="checkbox" name="selectedPaints" value="Apex Ultima" checked /></td>
                    <td>Apex Ultima</td>
                    <td>Asians Paints</td>
                    <td>Exterior</td>
                    <td>120</td>
                    <td>₹180</td>
                    <td><span class="status ok">Ok</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td><input type="checkbox" name="selectedPaints" value="WeatherCoat" checked /></td>
                    <td>WeatherCoat</td>
                    <td>Berger Paints</td>
                    <td>Exterior</td>
                    <td>15</td>
                    <td>₹220</td>
                    <td><span class="status low">Low</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td><input type="checkbox" name="selectedPaints" value="Excel Total" /></td>
                    <td>Excel Total</td>
                    <td>Nerolac</td>
                    <td>Exterior</td>
                    <td>60</td>
                    <td>₹210</td>
                    <td><span class="status ok">Ok</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

<script>
    function addToBill() {
        let items = [];
        document.querySelectorAll('input[type="checkbox"][name="selectedPaints"]:checked').forEach(cb => items.push(cb.value));
        let billItems = localStorage.getItem("billItems");
        billItems = billItems ? billItems.split("|") : [];
        items.forEach(i => { if(!billItems.includes(i)) billItems.push(i); });
        localStorage.setItem("billItems", billItems.join("|"));
        window.location.href = '/Bill/Index';
    }
</script>