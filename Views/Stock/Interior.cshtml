@{
    ViewData["Title"] = "Stock - Interior";
}

<div class="stock-container">

    <h2 class="stock-title">Stock - Interior</h2>

    <div class="stock-toolbar">
        <input type="text"
               class="stock-search"
               placeholder="Search by name, brand, or" />

        <button type="button"
                class="btn-primary"
                onclick="location.href='/Stock/AddPaint'">
            Add Paint
        </button>

        <button type="button" class="btn-primary" onclick="addToBill()">
            Add to Bill
        </button>
    </div>

    <div class="table-wrapper">
        <table class="stock-table">
            <thead>
                <tr>
                    <th>Select</th>
                    <th>Paint Name</th>
                    <th>Brand</th>
                    <th>Category</th>
                    <th>Quantity(L)</th>
                    <th>Price/L</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                <!-- =============================== -->
                <!-- NEWLY ADDED PAINT (FROM FORM) -->
                <!-- =============================== -->
                @if (TempData["PaintName"] != null)
                {
                    <tr>
                        <td>
                            <input type="checkbox"
                                   name="selectedPaints"
                                   value="@TempData["PaintName"]"
                                   checked />
                        </td>
                        <td>@TempData["PaintName"]</td>
                        <td>@TempData["Brand"]</td>
                        <td>@TempData["Category"]</td>
                        <td>@TempData["Quantity"]</td>
                        <td>@TempData["Price"]</td>
                        <td><span class="status ok">New</span></td>
                        <td>
                            <button type="button" class="btn-edit">Edit</button>
                            <button type="button" class="btn-delete">Delete</button>
                        </td>
                    </tr>
                }

                <!-- =============================== -->
                <!-- EXISTING STATIC ROWS (SAFE) -->
                <!-- =============================== -->
                <tr>
                    <td>
                        <input type="checkbox"
                               name="selectedPaints"
                               value="Tractor Emulsion"
                               checked />
                    </td>
                    <td>Tractor Emulsion</td>
                    <td>Asian Paints</td>
                    <td>Interior</td>
                    <td>120</td>
                    <td>180</td>
                    <td><span class="status ok">Ok</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>
                        <input type="checkbox"
                               name="selectedPaints"
                               value="Premium Emulsion"
                               checked />
                    </td>
                    <td>Premium Emulsion</td>
                    <td>Asian Paints</td>
                    <td>Interior</td>
                    <td>15</td>
                    <td>220</td>
                    <td><span class="status low">Low</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>

                <tr>
                    <td>
                        <input type="checkbox"
                               name="selectedPaints"
                               value="Royal" />
                    </td>
                    <td>Royal</td>
                    <td>Berger</td>
                    <td>Interior</td>
                    <td>60</td>
                    <td>210</td>
                    <td><span class="status ok">Ok</span></td>
                    <td>
                        <button type="button" class="btn-edit">Edit</button>
                        <button type="button" class="btn-delete">Delete</button>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

</div>

<!-- ================================ -->
<!-- ADD TO BILL JS (UNCHANGED) -->
<!-- ================================ -->
<script>
    function addToBill() {

        let items = [];
        document
            .querySelectorAll('input[type="checkbox"][name="selectedPaints"]:checked')
            .forEach(cb => {
                items.push(cb.value);
            });

        let billItems = localStorage.getItem("billItems");
        billItems = billItems ? billItems.split("|") : [];

        items.forEach(i => {
            if (!billItems.includes(i)) billItems.push(i);
        });

        localStorage.setItem("billItems", billItems.join("|"));

        window.location.href = '/Bill/Index';
    }
</script>
