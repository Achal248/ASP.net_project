@{
    ViewData["Title"] = "Stock";
}

<div class="stock-page">

    <!-- ADD CATEGORY BUTTON -->
    <div class="category-toolbar">
        <button class="btn-primary" onclick="openCategoryModal()">
            + Add Category
        </button>
    </div>

    <div class="stock-categories">

        <div class="stock-grid" id="categoryContainer">

            <a asp-controller="Stock" asp-action="Interior" class="stock-card">
                Interior
            </a>

            <a asp-controller="Stock" asp-action="Exterior" class="stock-card">
                Exterior
            </a>

            <a asp-controller="Stock" asp-action="Putty" class="stock-card">
                Putty
            </a>

            <a asp-controller="Stock" asp-action="Primer" class="stock-card">
                Primer
            </a>

        </div>

    </div>

</div>


<!-- CATEGORY MODAL -->
<div id="categoryModal" class="category-modal">

    <div class="modal-box">

        <h3>Add Category</h3>

        <input id="catName" type="text" placeholder="Category Name" />

        <textarea id="catDesc" placeholder="Description (optional)"></textarea>

        <div class="modal-buttons">
            <button class="btn-primary" onclick="addCategory()">Add</button>
            <button onclick="closeCategoryModal()">Cancel</button>
        </div>

    </div>

</div>


<script>

    function openCategoryModal() {
        document.getElementById("categoryModal").style.display = "flex";
    }

    function closeCategoryModal() {
        document.getElementById("categoryModal").style.display = "none";
    }

    function addCategory() {

        const name = document.getElementById("catName").value;

        if (name.trim() === "") {
            alert("Category name required");
            return;
        }

        const container = document.getElementById("categoryContainer");

        const card = document.createElement("a");

        card.className = "stock-card";
        card.innerText = name;

        container.appendChild(card);

        document.getElementById("catName").value = "";
        document.getElementById("catDesc").value = "";

        closeCategoryModal();
    }

</script>