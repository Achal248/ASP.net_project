@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ColorFill</title>

    <style>

        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: white; /* full white background */
            font-family: 'Segoe UI', sans-serif;
        }

        /* Card */

        .splash-card {
            width: 350px;
            height: 420px;
            background: white; /* card also white */
            border-radius: 30px;
            border: 2px solid #cfcfcf;
            box-shadow: 0 6px 12px rgba(0,0,0,0.25);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        /* Logo */

        .logo-img {
            width: 220px;
            margin-bottom: 20px;
        }

        /* Text */

        .subtitle {
            font-size: 14px;
            color: #222;
            margin-top: 5px;
        }

        .menu {
            font-size: 13px;
            margin-top: 6px;
            color: #333;
        }

    </style>

</head>

<body>

    <div class="splash-card">

        <img src="~/images/logo.jpeg" class="logo-img" />

        <div class="subtitle">
            Welcome to colorfill app
        </div>

        <div class="menu">
            • Stock • Labour • Billing
        </div>

    </div>

    <script>

        setTimeout(function(){

        window.location.href='/Account/Login';

        },2000);

    </script>

</body>
</html>