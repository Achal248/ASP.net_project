@{
    ViewData["Title"] = "Category";
}

<div class="category-container">

    <div class="category-header">

        <h2>Categories</h2>

        <button onclick="showForm()" class="btn btn-primary">
            Add Category
        </button>

    </div>

    <div id="categoryForm" class="category-form" style="display:none;">

        <input type="text" id="catName" placeholder="Category Name" class="form-control" />

        <textarea id="catDesc" placeholder="Description (optional)" class="form-control"></textarea>

        <button onclick="addCategory()" class="btn btn-success">
            Save
        </button>

    </div>

    <div class="category-grid" id="categoryGrid">

        <a asp-controller="Stock" asp-action="Interior" class="stock-card">
            Interior
        </a>

        <a asp-controller="Stock" asp-action="Exterior" class="stock-card">
            Exterior
        </a>

        <a asp-controller="Stock" asp-action="Putty" class="stock-card">
            Putty
        </a>

        <a asp-controller="Stock" asp-action="Primer" class="stock-card">
            Primer
        </a>

    </div>

</div>
<script>

    function showForm(){
        document.getElementById("categoryForm").style.display = "block";
    }

    function addCategory(){

        let name = document.getElementById("catName").value;

        if(name == ""){
            alert("Category name required");
            return;
        }

        let grid = document.getElementById("categoryGrid");

        let card = document.createElement("a");

        card.className = "stock-card";

        card.innerText = name;

        card.href = "/Stock";

        grid.appendChild(card);

        document.getElementById("catName").value="";
        document.getElementById("catDesc").value="";
    }

</script>